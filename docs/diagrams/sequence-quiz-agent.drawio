        <!-- ==================== Messages ==================== -->
        <!-- 1. Client -> Controller -->
        <mxCell id="m1" value="1. GET /session/{id}/next" style="html=1;verticalAlign=bottom;endArrow=block;rounded=1;strokeColor=#333333;fontSize=10;fontStyle=1;" edge="1" parent="1">
